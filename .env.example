# ─── Docker MySQL ────────────────────────────────────────────────────────────
# Used by docker-compose to initialise the MySQL container
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=videocall
MYSQL_USER=videocall
MYSQL_PASSWORD=password

# ─── Backend ────────────────────────────────────────────────────────────────

# Local dev: points to localhost. Docker: set automatically by compose.
DATABASE_URL="mysql://videocall:password@localhost:3306/videocall"

# Express session
SESSION_SECRET="change-this-to-a-long-random-string-minimum-32-chars"
SESSION_MAX_AGE_MS=604800000
# Development: false   Production: set to true (docker-compose.prod.yml overrides this)
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax

# Server
PORT=4000
NODE_ENV=development
# Development: localhost frontend origin
# Production: your domain e.g. "https://meet.example.com"
CLIENT_URL="http://localhost:5173"

# Email (nodemailer) — optional
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="VideoCall <noreply@example.com>"

# ─── Frontend ────────────────────────────────────────────────────────────────
# Development only — in Docker/production these are set as build ARGs (see docker-compose.prod.yml)

VITE_API_URL="/api"
VITE_SOCKET_URL=""

# WebRTC ICE servers
VITE_STUN_URL="stun:stun.l.google.com:19302"
# Production: replace with your coturn domain and TLS port e.g. "turn:turn.example.com:5349"
VITE_TURN_URL="turn:localhost:3478"
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
