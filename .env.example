# ─── Backend ────────────────────────────────────────────────────────────────

# MySQL connection string (used by Prisma)
DATABASE_URL="mysql://user:password@localhost:3306/videocall"

# Express session
SESSION_SECRET="change-this-to-a-long-random-string-minimum-32-chars"
SESSION_MAX_AGE_MS=604800000
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax

# Server
PORT=4000
NODE_ENV=development
CLIENT_URL="http://localhost:5173"

# Email (nodemailer) — optional, needed for Step 8
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="VideoCall <noreply@example.com>"

# ─── Frontend ────────────────────────────────────────────────────────────────

VITE_API_URL="http://localhost:4000/api"
VITE_SOCKET_URL="http://localhost:4000"

# WebRTC ICE servers
VITE_STUN_URL="stun:stun.l.google.com:19302"
VITE_TURN_URL="turn:localhost:3478"
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
